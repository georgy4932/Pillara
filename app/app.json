{
  "expo": {
    "name": "Pillara",
    "slug": "pillara",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "pillara",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.pillara",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Pillara uses notifications to help remind you about medicine routines and appointments."
      }
    },
    "android": {
      "package": "app.pillara",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F5F7"
      },
      "permissions": [
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
